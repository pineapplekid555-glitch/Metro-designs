# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Your bot's Application/Client ID (from the General Information page)
CLIENT_ID=your_client_id_here

# Optional: Your Discord server/guild ID for instant command registration (dev mode)
# Leave blank to register commands globally (takes up to 1 hour)
GUILD_ID=your_guild_id_here
